{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PDF State",
  "description": "Runtime state schema for PDF (v2 — configurable model tiers, channel rules, repair gates, MADE)",
  "type": "object",
  "required": ["stage", "round", "task_slug", "stages", "schema_version"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "description": "Schema version for migration support. v2 adds model_tier/channel_config/repair_gate/made fields.",
      "minimum": 1
    },
    "stage": {
      "type": "string",
      "description": "Current PDCA stage",
      "enum": ["plan", "do", "check", "act", "decompose", "child_exec", "meta_check", "done"]
    },
    "round": {
      "type": "integer",
      "description": "PDF cycle round number",
      "minimum": 1
    },
    "task_slug": {
      "type": "string",
      "description": "URL-friendly task identifier",
      "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
    },

    "=== v2 NEW fields ===": {},

    "model_tier": {
      "type": "object",
      "description": "Resolved model tier config for current cycle. Populated at init from spawn-config.yaml + domain overrides + CLI overrides.",
      "properties": {
        "plan":  { "$ref": "#/definitions/stageTierConfig" },
        "do":    { "$ref": "#/definitions/stageTierConfig" },
        "check": { "$ref": "#/definitions/stageTierConfig" },
        "act":   { "$ref": "#/definitions/stageTierConfig" },
        "overrides": {
          "type": "object",
          "description": "Runtime model overrides (from CLI --model-tier). Key=stage.field, value=model_name.",
          "additionalProperties": { "type": "string" }
        },
        "override_reason": {
          "type": "string",
          "description": "Optional reason for any model override, set at init time."
        }
      },
      "additionalProperties": false
    },
    "channel_config": {
      "type": "object",
      "description": "Resolved channel configuration for current cycle. Populated at init, may be overridden by LLM at Plan P0.",
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["lite", "standard", "full"],
          "description": "Active channel profile."
        },
        "overrides": {
          "type": "object",
          "description": "LLM-driven overrides to channel behavior. Key=setting, value=override_value.",
          "additionalProperties": true
        },
        "llm_override_reason": {
          "type": "string",
          "description": "When LLM overrides the channel in Plan P0, record the reason here."
        }
      },
      "required": ["profile"],
      "additionalProperties": false
    },
    "repair_gate_config": {
      "type": "object",
      "description": "Resolved repair gate limits for current cycle. Read from spawn-config.yaml or domain config.",
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["lite", "standard", "full"],
          "description": "Active repair gate profile."
        },
        "max_plan_loop": {
          "type": "integer",
          "description": "Max plan remediation loops before degrade/pause.",
          "minimum": 0,
          "default": 2
        },
        "max_do_loop": {
          "type": "integer",
          "description": "Max do remediation loops before degrade/pause.",
          "minimum": 0,
          "default": 3
        },
        "flaky_retry_max": {
          "type": "integer",
          "description": "Max flaky test retry attempts.",
          "minimum": 0,
          "default": 3
        },
        "degrade_on_exceed": {
          "type": "string",
          "enum": ["record_and_proceed", "auto_downgrade_lite", "pause_and_ask"],
          "description": "Behavior when loop limits are exceeded.",
          "default": "pause_and_ask"
        },
        "repair_gate_bypassed": {
          "type": "boolean",
          "description": "Set true when repair gate was bypassed via degrade action.",
          "default": false
        },
        "degrade_reason": {
          "type": "string",
          "description": "Reason for repair gate bypass/degrade."
        }
      },
      "additionalProperties": false
    },
    "made_config": {
      "type": "object",
      "description": "Resolved MADE exploration config for current cycle. Read from spawn-config.yaml or domain config.",
      "properties": {
        "trigger_depth": {
          "type": "integer",
          "description": "Minimum task depth to trigger MADE exploration.",
          "minimum": 1,
          "default": 2
        },
        "n_explorers_min": {
          "type": "integer",
          "description": "Minimum number of MADE explorers.",
          "minimum": 1,
          "default": 2
        },
        "n_explorers_max": {
          "type": "integer",
          "description": "Maximum number of MADE explorers.",
          "maximum": 8,
          "default": 6
        },
        "max_parallel": {
          "type": "integer",
          "description": "Maximum parallel MADE tasks.",
          "minimum": 1,
          "default": 2
        },
        "fallback_on_failure": {
          "type": "string",
          "enum": ["skip", "internal_analysis", "single_synthesizer"],
          "description": "Fallback when all MADE explorers fail.",
          "default": "skip"
        }
      },
      "additionalProperties": false
    },

    "=== v1 existing fields ===": {},

    "stages": {
      "type": "object",
      "description": "Per-stage N/M configuration",
      "required": ["plan", "do", "check", "act"],
      "properties": {
        "plan":  { "$ref": "#/definitions/stageConfig" },
        "do":    { "$ref": "#/definitions/stageConfig" },
        "check": { "$ref": "#/definitions/stageConfig" },
        "act":   { "$ref": "#/definitions/stageConfig" }
      },
      "additionalProperties": false
    },
    "arbitration_needed": {
      "type": "boolean",
      "description": "Whether arbitrator intervention is needed"
    },
    "pending_remediation": {
      "type": "boolean",
      "description": "Whether remediation is in progress"
    },
    "plan_rem_loop": {
      "type": "integer",
      "description": "Plan-stage remediation iteration count (design_flaw). Evaluated against repair_gate_config.max_plan_loop.",
      "minimum": 0
    },
    "do_rem_loop": {
      "type": "integer",
      "description": "Do-stage remediation iteration count (bug). Evaluated against repair_gate_config.max_do_loop.",
      "minimum": 0
    },
    "remediation_type": {
      "type": "string",
      "description": "Type of remediation. false_positive and flaky_test do NOT consume any counter.",
      "enum": ["bug", "design_flaw", "false_positive", "flaky_test"]
    },
    "routing_decision": {
      "type": "string",
      "description": "Routing decision from the Check repair gate"
    },
    "check_findings_p1": {
      "type": "integer",
      "description": "Number of P1 findings from Check stage",
      "minimum": 0
    },
    "artifacts": {
      "type": "array",
      "description": "List of artifact records produced so far",
      "items": { "$ref": "#/definitions/artifactRecord" }
    },
    "parent_mode": {
      "type": "boolean",
      "description": "Whether this is a parent in recursive decomposition"
    },
    "decomposition": {
      "type": "object",
      "description": "Recursive decomposition state (null if parent_mode=false)",
      "required": ["contract_path", "meta_check"],
      "properties": {
        "contract_path": { "type": "string" },
        "child_teams": {
          "type": "object",
          "patternProperties": {
            "^[a-zA-Z0-9_-]+$": {
              "type": "object",
              "required": ["status"],
              "properties": {
                "status": { "type": "string", "enum": ["pending", "running", "done", "failed"] },
                "workspace": { "type": "string" },
                "state_file": { "type": "string" }
              }
            }
          }
        },
        "meta_check": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": { "type": "string", "enum": ["pending", "in_progress", "passed", "failed"] },
            "p1_count": { "type": "integer", "minimum": 0 }
          }
        },
        "child_dependency_order": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "agentStatus": {
      "type": "string",
      "description": "Agent execution status",
      "enum": ["pending", "running", "done", "failed"]
    },
    "artifactRecord": {
      "type": "object",
      "description": "Typed artifact entry with stage provenance",
      "required": ["path", "stage"],
      "properties": {
        "path": { "type": "string", "description": "Relative file path" },
        "stage": { "type": "string", "enum": ["plan", "do", "check", "act"] },
        "role": { "type": "string", "description": "Role: plan|do_output|review|check|act" },
        "completed_at": { "type": "string", "description": "ISO 8601 timestamp" }
      },
      "additionalProperties": false
    },
    "stageConfig": {
      "type": "object",
      "required": ["N", "M"],
      "properties": {
        "N": {
          "type": "integer",
          "description": "Number of parallel executors (1-7)",
          "minimum": 1,
          "maximum": 7
        },
        "M": {
          "type": "integer",
          "description": "Number of parallel reviewers (1-8)",
          "minimum": 1,
          "maximum": 8
        },
        "doer_status": {
          "type": "object",
          "description": "Per-executor status map. Values use AgentStatus enum.",
          "additionalProperties": { "$ref": "#/definitions/agentStatus" }
        },
        "reviewer_status": {
          "type": "object",
          "description": "Per-reviewer status map. Values use AgentStatus enum.",
          "additionalProperties": { "$ref": "#/definitions/agentStatus" }
        }
      },
      "additionalProperties": false
    },
    "stageTierConfig": {
      "type": "object",
      "description": "Model tier config per stage (v2)",
      "properties": {
        "p1_model": { "type": "string", "description": "Executor model (haiku/sonnet/opus)" },
        "p2_model": { "type": "string", "description": "Reviewer model (haiku/sonnet/opus)" },
        "p1_subagent_type": { "type": "string" },
        "p2_subagent_type": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
